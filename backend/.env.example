# OpenAI-compatible LLM API settings.
# Put real values in backend/.env, not in this example file.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://your-hostname/v1
LLM_MODEL=your_model_id_here

# Production database. Leave unset locally to use SQLite.
# Use the Supabase Postgres pooled connection string in deployment.
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Production image storage. Leave unset locally to use backend/uploads.
# Create this bucket in Supabase Storage and make it public.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_STORAGE_BUCKET=diet-images

# Optional legacy compatibility. The app still reads these if LLM_* is absent.
# MODELSCOPE_API_KEY=your_modelscope_api_key_here
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# MODELSCOPE_MODEL=Qwen/Qwen3.5-397B-A17B
